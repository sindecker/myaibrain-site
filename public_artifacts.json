{
  "_meta": {
    "purpose": "Single source of truth for every PUBLIC-FACING content artifact (README, CHANGELOG, marketing page, PyPI listing, social bio) that should reflect the current AIBrain version state. Read by verify-public.py on every deploy and by the smoke test cron every 15 minutes. The 'must_contain' assertions PROVE the artifact is current; 'must_not_contain' catches the stale version drift that fired across the public surface in 2026-04 (v1.2.4 in sindecker/aibrain README for 5 days after v1.4.0 shipped to PyPI; aibrain-compress repo empty for 2 days).",
    "version": "1.0.0",
    "last_updated": "2026-04-12",
    "live_truth_source": "decker_system/00_meta/aibrain_live_truth_v1_4_0.md (canonical version + numeric truth)",
    "current_version": "1.4.1",
    "stale_versions": ["1.2.0", "1.2.1", "1.2.2", "1.2.3", "1.2.4", "1.3.0", "1.3.1", "1.4.0"],
    "stale_count_claims": ["200+ workflow", "240 workflow", "869 test", "165+ API", "45-page", "45_page", "45 page"]
  },
  "artifacts": [
    {
      "id": "sindecker_aibrain_readme",
      "url": "https://raw.githubusercontent.com/sindecker/aibrain/main/README.md",
      "purpose": "Public marketing README on the discovery repo. Patterns chosen to catch HEADER / BADGE / SECTION-HEADER staleness while still allowing historical comparison phrases (e.g., 'Up from 869 in the v1.2.4 release') and historical CHANGELOG entries.",
      "must_contain": [
        "AIBrain-v1.4.1",
        "60 ready-to-run",
        "tests-2065",
        "53-page",
        "What's New in v1.4.1"
      ],
      "must_not_contain": [
        "AIBrain-v1.2.4",
        "AIBrain-v1.3",
        "AIBrain-v1.4.0-",
        "tests-869",
        "workflows-200",
        "200+ ready-to-run",
        "200+ workflow scripts",
        "What's New in v1.2.4",
        "What's New in v1.3"
      ],
      "owner_repo": "sindecker/aibrain"
    },
    {
      "id": "sindecker_aibrain_changelog",
      "url": "https://raw.githubusercontent.com/sindecker/aibrain/main/CHANGELOG.md",
      "purpose": "Public CHANGELOG must have the current version as its top entry. Older versions remain in the file as historical entries — patterns target the TOP entry, not the existence of any 1.4.x string anywhere in the file.",
      "must_contain": [
        "## [1.4.1]",
        "AIBRAIN_SIGNING_KEY now mandatory",
        "Honest-rubric divergence loop",
        "Hippocampus-as-a-service"
      ],
      "must_not_contain": [],
      "owner_repo": "sindecker/aibrain"
    },
    {
      "id": "sindecker_aibrain_guidebook",
      "url": "https://raw.githubusercontent.com/sindecker/aibrain/main/GUIDEBOOK.md",
      "purpose": "Public guidebook version line + counts",
      "must_contain": [
        "Version:** 1.4.1"
      ],
      "must_not_contain": [
        "Version:** 1.2.4",
        "Version:** 1.3",
        "Version:** 1.4.0",
        "200+ workflow scripts",
        "165+ REST/WebSocket"
      ],
      "owner_repo": "sindecker/aibrain"
    },
    {
      "id": "sindecker_aibrain_compress_readme",
      "url": "https://raw.githubusercontent.com/sindecker/aibrain-compress/main/README.md",
      "purpose": "aibrain-compress standalone library README",
      "must_contain": [
        "aibrain-compress",
        "Pure Python",
        "pip install"
      ],
      "must_not_contain": [],
      "owner_repo": "sindecker/aibrain-compress",
      "skip_until_populated": false
    },
    {
      "id": "myaibrain_landing_page",
      "url": "https://myaibrain.org",
      "purpose": "Customer-facing landing page — version + tagline",
      "must_contain": [
        "AIBrain"
      ],
      "must_not_contain": [
        ">>200+ workflows<<",
        ">>v1.2.4<<",
        ">>869 tests<<"
      ],
      "owner_repo": "DeckerOps/myaibrain-site"
    },
    {
      "id": "pypi_aibrain",
      "url": "https://pypi.org/pypi/aibrain/json",
      "purpose": "Parent aibrain package on PyPI — latest version must match live truth current_version. Pulls JSON from the PyPI API and asserts the version field matches.",
      "must_contain": [
        "\"version\":\"1.4.1\""
      ],
      "must_not_contain": [],
      "owner_repo": "DeckerOps/aibrain"
    },
    {
      "id": "pypi_aibrain_compress",
